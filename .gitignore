__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
data/*.db
data/*.db-journal
# Generated article artifacts (anywhere under content/journals/<slug>/...)
content/**/article-raw.md
content/**/article.html
content/**/article.pdf
content/**/article.typ
content/**/article.epub
content/**/conversion.log
content/**/.versions/
content/**/source.docx
content/**/articles/*/assets/
content/**/_unfiled/*/assets/
# Per-article copy of the journal stylesheet (the canonical template/article.css
# is committed; copies under articles/ are regenerated each render).
content/**/articles/*/article.css
content/**/_unfiled/*/article.css
# Issue-level artifacts
content/**/issue.pdf
content/**/issue-toc.json
content/**/_cover.pdf
content/**/_cover.typ
content/**/_front_matter.pdf
content/**/_front_matter.typ
# Hold-out article directories (uploads not yet committed; canonical article.md will be committed when ready)
content/**/_unfiled/
# Per-article PDF preview rasters
content/**/preview/
_dropbox/
*.log
.DS_Store
.vscode/
.idea/
